# ──────────────────────────────────────────────────
# 数据库（MySQL，规范 2-2：北京时间）
# ──────────────────────────────────────────────────
# Docker 一键部署时，DATABASE_URL 指向内部 mysql 容器（主机名为 mysql）
# 外部独立数据库部署时，将 mysql 替换为实际 IP/域名
DATABASE_URL="mysql://root:${MYSQL_ROOT_PASSWORD}@mysql:3306/${MYSQL_DATABASE}"

# ── MySQL 容器配置（仅 Docker 一键部署时需要） ─────
# MySQL root 密码，生产环境务必改为强密码
MYSQL_ROOT_PASSWORD=change-me-mysql-root-password
# 数据库名
MYSQL_DATABASE=mindmap_db

# Node.js 运行时时区（规范 2-2：强制北京时间）
TZ=Asia/Shanghai

# ──────────────────────────────────────────────────
# JWT 鉴权（规范 4-3）
# ──────────────────────────────────────────────────
# 至少 32 位随机字符串，生产环境务必更换
JWT_SECRET="change-me-to-a-long-random-secret-string-at-least-32-chars"
# JWT 有效期（如 7d、24h）
JWT_EXPIRES_IN="7d"

# ──────────────────────────────────────────────────
# 功能开关
# ──────────────────────────────────────────────────
# true = 使用服务端 API（Next.js + MySQL）；false = 纯前端 mock（localStorage）
NEXT_PUBLIC_USE_API=false

# ──────────────────────────────────────────────────
# 初始化 Seed（首次空库时自动创建组织数据）
# 规范：不允许在代码里写死凭据，必须通过此处配置
# ──────────────────────────────────────────────────
# 管理员工号（与 mock/org.ts CEO 绑定，seed 时将其 employeeNo 替换为此值）
SEED_ADMIN_NO="E001"
# 管理员初始密码（生产环境务必修改为强密码，建议 12 位以上含大小写+数字+符号）
SEED_ADMIN_PASSWORD="change-me-strong-password"
# 其他 seed 用户的统一初始密码（员工首次登录后应自行修改）
SEED_DEFAULT_PASSWORD="change-me-default-password"

# ──────────────────────────────────────────────────
# 钉钉集成（可选）
# 配置后，系统内通知将通过机器人单聊推送给已绑定用户
# 留空则钉钉推送静默跳过，不影响站内通知
# ──────────────────────────────────────────────────
DINGTALK_APP_KEY=your_app_key          # 钉钉企业内部应用的 AppKey
DINGTALK_APP_SECRET=your_app_secret    # 钉钉企业内部应用的 AppSecret
DINGTALK_APP_ID=your_app_id            # 钉钉企业内部应用的 AppId（用于SSO登录）
DINGTALK_ROBOT_CODE=your_robot_code    # 机器人的 robotCode（在钉钉开放平台应用管理 → 机器人中获取）
DINGTALK_ROOT_DEPT_ID=1                # 同步部门树的根部门 ID（钉钉默认根部门为 1）

# ──────────────────────────────────────────────────
# 定时任务鉴权（Cron 容器调用内部 API 时使用）
# 生产环境务必设置为随机长字符串
# ──────────────────────────────────────────────────
CRON_SECRET=change-me-cron-secret-random-string

# ──────────────────────────────────────────────────
# 前端基础URL（用于钉钉SSO回调等）
# ──────────────────────────────────────────────────
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
